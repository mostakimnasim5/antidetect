{
    "version": 6,
    "cmakeMinimumRequired": {
        "major": 3,
        "minor": 24,
        "patch": 0
    },
    "configurePresets": [
        {
            "name": "msvc-debug",
            "displayName": "MSVC Debug",
            "description": "MSVC compiler with debug symbols",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_FLAGS": "/Zi /Od /MDd /W4",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreadedDebug"
            }
        },
        {
            "name": "msvc-release",
            "displayName": "MSVC Release",
            "description": "MSVC compiler optimized release build",
            "generator": "Visual Studio 17 2022",
            "binaryDir": "${sourceDir}/build/msvc-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_FLAGS": "/O2 /Ob2 /Oi /Ot",
                "CMAKE_MSVC_RUNTIME_LIBRARY": "MultiThreaded"
            }
        },
        {
            "name": "mingw-debug",
            "displayName": "MinGW Debug",
            "description": "MinGW-w64 GCC debug build",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build/mingw-debug",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_C_COMPILER": "gcc"
            },
            "condition": {
                "type": "equals",
                "lhs": "${host_os}",
                "rhs": "Windows"
            }
        },
        {
            "name": "mingw-release",
            "displayName": "MinGW Release",
            "description": "MinGW-w64 GCC optimized release",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/build/mingw-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release",
                "CMAKE_CXX_COMPILER": "g++",
                "CMAKE_C_COMPILER": "gcc"
            }
        },
        {
            "name": "ninja-release",
            "displayName": "Ninja Release",
            "description": "Ninja generator for fast builds",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/build/ninja-release",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Release"
            }
        }
    ],
    "buildPresets": [
        {
            "name": "dev",
            "configurePreset": "msvc-debug",
            "jobs": 8
        },
        {
            "name": "prod",
            "configurePreset": "msvc-release",
            "jobs": 16
        },
        {
            "name": "quick",
            "configurePreset": "ninja-release",
            "jobs": 8
        }
    ],
    "testPresets": [
        {
            "name": "all",
            "configurePreset": "msvc-release",
            "output": {
                "outputOnFailure": true
            }
        }
    ]
}
